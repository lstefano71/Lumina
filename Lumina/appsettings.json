{
  "Lumina": {
    "Wal": {
      "DataDirectory": "data/streams",
      "MaxWalSizeBytes": 104857600,
      "EnableWriteThrough": true,
      "FlushIntervalMs": 100
    },
    "Compaction": {
      "IntervalMinutes": 10,
      "L1IntervalMinutes": 10,
      "L2IntervalHours": 24,
      "MaxDynamicKeys": 100,
      "ParquetOutputDirectory": "data/storage/parquet"
    },
    "Query": {
      "MaxResults": 10000,
      "QueryTimeoutSeconds": 30
    },
    "Ingestion": {
      "HttpPort": 5000,
      "MaxRequestBodySize": 10485760
    },
    "DeploymentMode": "Intranet"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}