{
  "Lumina": {
    "Wal": {
      "DataDirectory": "data-dev",
      "MaxWalSizeBytes": 10485760,
      "EnableWriteThrough": false,
      "FlushIntervalMs": 1000
    },
    "Compaction": {
      "IntervalMinutes": 1,
      "L1IntervalMinutes": 1,
      "L2IntervalHours": 1,
      "MaxDynamicKeys": 50,
      "ParquetOutputDirectory": "data-dev/parquet",
      "L1Directory": "data-dev/l1",
      "L2Directory": "data-dev/l2",
      "CursorDirectory": "data-dev/cursors"
    },
    "Query": {
      "MaxResults": 1000,
      "QueryTimeoutSeconds": 10
    },
    "Ingestion": {
      "HttpPort": 5000,
      "MaxRequestBodySize": 1048576
    },
    "DeploymentMode": "Intranet"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Lumina": "Debug"
    }
  }
}